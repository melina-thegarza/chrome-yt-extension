{
  "manifest_version": 3,
  "name": "YouTube Auto Mute Ads",
  "version": "1.0",
  "description": "Automatically mutes YouTube ads",
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
